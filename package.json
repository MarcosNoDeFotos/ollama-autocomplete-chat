{
  "name": "llama3-autocomplete-and-chat",
  "displayName": "llama3 Autocomplete and Chat",
  "description": "Conecta con Ollama usando el modelo llama3 para acceder a un chat en local y autocompletar código",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MarcosNoDeFotos/ollama-autocomplete-chat.git"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "Ollama Autocomplete and Chat Configuration",
      "properties": {
        "ollamaAutocompleteChat.model": {
          "type": "string",
          "default": "llama3",
          "description": "Modelo de Ollama a usar para autocompletar y chat"
        },
        "ollamaAutocompleteChat.endpoint": {
          "type": "string",
          "default": "http://localhost:11434/api/generate",
          "description": "URL del endpoint de Ollama para generar respuestas"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.118.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "node-fetch": "3.3.2",
    "marked": "18.0.3"
  }
}
